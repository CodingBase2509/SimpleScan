<section class="scanned-pages-strip" aria-label="@AriaLabel">
    @if (Pages.Count == 0)
    {
        <div class="scanned-pages-strip__empty">
            <MudText Typo="Typo.body2" Color="Color.Secondary">@EmptyMessage</MudText>
        </div>
    }
    else
    {
        @foreach (var page in Pages)
        {
            <article class="@GetItemClass(page)">
                <button class="scanned-pages-strip__thumbnail-button"
                        type="button"
                        disabled="@Disabled"
                        aria-label="@GetOpenPageLabel(page)"
                        @onclick="() => PageSelected.InvokeAsync(page.Id)">
                    @if (CanShowThumbnail(page))
                    {
                        <img class="scanned-pages-strip__thumbnail"
                             src="@ScanPageViewModel.GetThumbnailUrl(DocumentId, page.Id)"
                             alt="@GetThumbnailAlt(page)"/>
                    }
                    else
                    {
                        <span class="scanned-pages-strip__thumbnail scanned-pages-strip__thumbnail--file">
                            <MudIcon Icon="@Icons.Material.Filled.Description"
                                     Size="Size.Small"/>
                            <span>@GetFileExtensionLabel(page)</span>
                        </span>
                    }
                </button>

                <div class="scanned-pages-strip__meta">
                    <span class="scanned-pages-strip__number">@(page.PageNumber)</span>
                </div>

                <span class="scanned-pages-strip__actions actions__forward">
                    <IconButton Icon="@Icons.Material.Filled.KeyboardArrowLeft"
                                Tooltip="Move page left"
                                AriaLabel="@GetMoveEarlierLabel(page)"
                                Size="Size.Small"
                                Disabled="@(Disabled || page.PageNumber <= 1)"
                                OnClick="@(_ => MovePageEarlier.InvokeAsync(page.Id))"/>
                </span>
                <span class="scanned-pages-strip__actions actions__backwards">
                    <IconButton Icon="@Icons.Material.Filled.KeyboardArrowRight"
                                Tooltip="Move page right"
                                AriaLabel="@GetMoveLaterLabel(page)"
                                Size="Size.Small"
                                Disabled="@(Disabled || page.PageNumber >= Pages.Count)"
                                OnClick="@(_ => MovePageLater.InvokeAsync(page.Id))"/>
                </span>
                <span class="scanned-pages-strip__actions actions__delete">
                    <IconButton Icon="@Icons.Material.Filled.Delete"
                                Tooltip="Delete page"
                                AriaLabel="@GetDeleteLabel(page)"
                                Size="Size.Small"
                                Color="Color.Error"
                                Disabled="@Disabled"
                                OnClick="@(_ => DeletePage.InvokeAsync(page.Id))"/>
                </span>
            </article>
        }
    }
</section>
