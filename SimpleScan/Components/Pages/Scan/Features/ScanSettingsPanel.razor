<section class="scan-settings-panel">
    <MudText Typo="Typo.h6">Scan settings</MudText>

    <div class="scan-settings-panel__fields">
        <MudSelect T="int"
                   Label="Resolution"
                   Value="@SelectedDpi"
                   ValueChanged="@OnDpiChangedAsync"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Disabled="@Disabled">
            @foreach (var dpi in SupportedDpi)
            {
                <MudSelectItem T="int" Value="@dpi">@($"{dpi} DPI")</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="ScanColorMode"
                   Label="Color mode"
                   Value="@SelectedColorMode"
                   ValueChanged="@OnColorModeChangedAsync"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Disabled="@Disabled">
            @foreach (var colorMode in SupportedColorModes)
            {
                <MudSelectItem T="ScanColorMode" Value="@colorMode">@GetColorModeLabel(colorMode)</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="string"
                   Label="Paper size"
                   Value="@SelectedPaperSize"
                   ValueChanged="@OnPaperSizeChangedAsync"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Disabled="@Disabled">
            @foreach (var paperSize in SupportedPaperSizes)
            {
                <MudSelectItem T="string" Value="@paperSize">@paperSize</MudSelectItem>
            }
        </MudSelect>

        <MudSelect T="string"
                   Label="Source"
                   Value="@SelectedSource"
                   ValueChanged="@OnSourceChangedAsync"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Disabled="@Disabled">
            @foreach (var source in SupportedSources)
            {
                <MudSelectItem T="string" Value="@source">@source</MudSelectItem>
            }
        </MudSelect>

        <MudSwitch T="bool"
                   Label="Duplex"
                   Value="@SelectedDuplex"
                   ValueChanged="@OnDuplexChangedAsync"
                   Disabled="@(Disabled || !SupportsDuplex)"
                   Color="Color.Primary"/>
    </div>
</section>
