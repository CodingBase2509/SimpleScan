<section class="device-selection-panel">
    <div class="device-selection-panel__header">
        <MudText Typo="Typo.h6">Available devices</MudText>

        <StatusBadge Label="@DiscoveryStatusLabel"
                     Icon="@Icons.Material.Filled.RadioButtonUnchecked"
                     Color="Color.Default"/>
    </div>

    <DeviceList Devices="@Devices"
                SelectedDeviceId="@SelectedDeviceId"
                IsLoading="@IsLoading"
                ErrorMessage="@ErrorMessage"
                SelectedDeviceIdChanged="@SelectedDeviceIdChanged"/>
</section>
