<div class="loading-state @Class"
     style="@Style"
     role="status"
     aria-live="polite"
     @attributes="UserAttributes">
    <MudProgressCircular Color="@Color"
                         Size="@Size"
                         Indeterminate="true"/>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <MudText Typo="Typo.body2"
                 Color="Color.Secondary">
            @Message
        </MudText>
    }
</div>
